{
  "name": "merfluence",
  "version": "1.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0 <22.23.0"
  },
  "scripts": {
    "build:view": "vite build --config vite.view.config.js",
    "build:config": "vite build --config vite.config.config.js",
    "build": "npm run build:view && npm run build:config",
    "dev:view": "vite --config vite.view.config.js",
    "dev:config": "vite --config vite.config.config.js",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:browser:headed": "vitest --project browser --browser.headless=false",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:forge": "forge lint",
    "deploy:staging": "npm run build && forge deploy -e staging",
    "deploy:production": "npm run build && forge deploy -e production",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.1",
    "@forge/bridge": "^4.0.0",
    "codemirror": "^6.0.1",
    "dompurify": "^3.2.3",
    "mermaid": "^11.4.1",
    "mermaid-10": "npm:mermaid@^10.9.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.5",
    "@forge/cli": "13.1.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^17.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "size-limit": "^12.1.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "yaml": "^2.9.0"
  }
}
