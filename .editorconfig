; Matches .prettierrc.json, for editors that read neither Prettier nor ESLint.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Two trailing spaces are a hard line break in Markdown.
trim_trailing_whitespace = false
